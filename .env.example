# Equity Research Lab — Environment Variables Template
# Copie pra .env e preencha os valores reais.
# .env está no .gitignore — nunca commitar.

# Anthropic API (opcional — só se for migrar Layer 3 do Cowork pra API)
ANTHROPIC_API_KEY=

# Caminhos (defaults funcionam, ajuste se quiser outro local)
DATA_DIR=./data
LOG_DIR=./logs

# OneDrive — onde o Cowork escreve análises e onde fica o backup
# Mac: /Users/SEU-USER/OneDrive/research_lab
# Linux: /home/SEU-USER/OneDrive/research_lab
ONEDRIVE_PATH=

# Logging
LOG_LEVEL=INFO
